@model RegisterViewModel
@{
    ViewData["Title"] = "Registrarse";
    Layout = "_AuthLayout";
}

<div class="card card-md">
    <div class="card-body">
        <h2 class="h2 text-center mb-4">Crear cuenta</h2>

        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

        <form asp-action="Register" method="post" autocomplete="off" novalidate>
            <div class="mb-3">
                <label asp-for="NombreCompleto" class="form-label"></label>
                <input asp-for="NombreCompleto" class="form-control" placeholder="Juan Pérez" autofocus />
                <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="nombre@ejemplo.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-2">
                <label asp-for="ConfirmarPassword" class="form-label"></label>
                <input asp-for="ConfirmarPassword" class="form-control" />
                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
            </div>

            <div class="form-footer mt-4">
                <button type="submit" class="btn btn-primary w-100">Crear cuenta</button>
            </div>
        </form>
    </div>

    <div class="hr-text">żYa tenés cuenta?</div>
    <div class="card-body">
        <a asp-action="Login" class="btn btn-outline-primary w-100">Iniciar sesión</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            var summary = $('[data-valmsg-summary]');
            if (summary.find('li').length === 0) {
                summary.closest('.alert').hide();
            }

            $('form').on('submit', function () {
                setTimeout(function () {
                    var sum = $('[data-valmsg-summary]');
                    if (sum.find('li').length > 0) {
                        sum.closest('.alert').show();
                    }
                }, 50);
            });
        });
    </script>
}
