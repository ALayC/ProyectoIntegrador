@model PaginadoViewModel<ClienteListViewModel>
@{
ViewData["Title"] = "Mis Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people"></i> Mis Clientes</h2>
  <a asp-action="Crear" class="btn btn-primary">
  <i class="bi bi-plus-circle"></i> Nuevo Cliente
    </a>
</div>

@if (Model.Datos.Count == 0)
{
    <div class="alert alert-info">
  <i class="bi bi-info-circle"></i> No hay clientes registrados aún.
    </div>
}
else
{
    <div class="table-responsive">
    <table class="table table-hover align-middle">
   <thead class="table-light">
   <tr>
     <th>RUT</th>
        <th>Razón Social</th>
      <th>Email</th>
        <th>Estado</th>
   <th class="text-end">Acciones</th>
  </tr>
        </thead>
       <tbody>
       @foreach (var cliente in Model.Datos)
                {
           var esInactivo = cliente.Estado == "Inactivo";
      <tr class="@(esInactivo ? "text-muted text-decoration-line-through" : "")">
        <td>@cliente.Rut</td>
  <td>@cliente.RazonSocial</td>
       <td>@cliente.Email</td>
        <td>
            @if (esInactivo)
   {
           <span class="badge bg-secondary">Inactivo</span>
  }
    else
              {
     <span class="badge bg-success">Activo</span>
  }
         </td>
        <td class="text-end">
      <a asp-action="Editar" asp-route-id="@cliente.Id"
           class="btn btn-sm btn-outline-primary" title="Editar">
       <i class="bi bi-pencil"></i>
   </a>
      @if (!esInactivo)
       {
     <form asp-action="Desactivar" asp-route-id="@cliente.Id"
       method="post" class="d-inline"
   onsubmit="return confirm('żEstás seguro de desactivar este cliente?');">
          <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar">
       <i class="bi bi-x-circle"></i>
    </button>
    </form>
  }
     </td>
         </tr>
              }
 </tbody>
     </table>
    </div>

    @* Paginación *@
    @if (Model.TotalPaginas > 1)
  {
        <nav aria-label="Paginación de clientes">
     <ul class="pagination justify-content-center">
      <li class="page-item @(Model.TienePaginaAnterior ? "" : "disabled")">
       <a class="page-link" asp-action="Index"
       asp-route-pagina="@(Model.Pagina - 1)"
  asp-route-cantidadPorPagina="@Model.CantidadPorPagina">
       &laquo; Anterior
     </a>
  </li>

 @for (int i = 1; i <= Model.TotalPaginas; i++)
          {
  <li class="page-item @(i == Model.Pagina ? "active" : "")">
    <a class="page-link" asp-action="Index"
     asp-route-pagina="@i"
              asp-route-cantidadPorPagina="@Model.CantidadPorPagina">@i</a>
       </li>
     }

   <li class="page-item @(Model.TienePaginaSiguiente ? "" : "disabled")">
    <a class="page-link" asp-action="Index"
      asp-route-pagina="@(Model.Pagina + 1)"
              asp-route-cantidadPorPagina="@Model.CantidadPorPagina">
         Siguiente &raquo;
            </a>
    </li>
        </ul>
        </nav>

  <p class="text-center text-muted">
Mostrando página @Model.Pagina de @Model.TotalPaginas
     (@Model.TotalRegistros registros en total)
        </p>
    }
}
